.env
__pycache__/
*.pyc
*.pyo

# data — all of it, nothing personal should be tracked
data/
# throwaway ALLES_DATA dirs from isolated test runs (each holds a scratch aide.db + vault)
.tmp_*/
# ...except the hwfit model catalog: it's reference data that ships with the
# repo (the cookbook is empty without it). un-ignore just that one.
!services/hwfit/data/
!services/hwfit/data/hf_models.json

# stray runtime dbs + restore backups at the repo root — never track user data
/aide.db
/aide.db-shm
/aide.db-wal
/autorun_test.db
/alles.db
aide-pre-restore-*/
# stray tmp scratch files (the .tmp_*/ rule above only matches dirs)
.tmp_*

# logs
*.log
server*.log

# graphify knowledge-graph output — local only, never track
graphify-out/

# ide / local tooling + agent instruction files — never track
.claude/
.vscode/
CLAUDE.md
AGENTS.md
aide.md

# python
venv/
.venv/
*.egg-info/
dist/
build/
node_modules/
.cmbuild/
