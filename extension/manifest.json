{
  "manifest_version": 3,
  "name": "alles vault autofill",
  "version": "0.1.0",
  "description": "Fill logins from your self-hosted alles vault (talks to the localhost vault API).",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://*.localhost:8000/*",
    "http://secrets.localhost:8000/*"
  ],
  "action": { "default_popup": "popup.html", "default_title": "alles autofill" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["content.js"], "run_at": "document_idle" }
  ]
}
