{
  "name": "alles-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Capacitor shell that wraps the self-hosted alles PWA as an installable iOS/Android app",
  "scripts": {
    "add:ios": "npx cap add ios",
    "add:android": "npx cap add android",
    "sync": "npx cap sync",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "run:ios": "npx cap run ios",
    "run:android": "npx cap run android"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/android": "^6.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0"
  }
}
