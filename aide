#!/usr/bin/env bash
# alias launcher for the alles CLI (see ./alles)
src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  d="$(cd -P "$(dirname "$src")" && pwd)"; src="$(readlink "$src")"
  [[ $src != /* ]] && src="$d/$src"
done
dir="$(cd -P "$(dirname "$src")" && pwd)"

for py in python3 python; do
  if command -v "$py" >/dev/null 2>&1; then exec "$py" "$dir/cli.py" "$@"; fi
done
echo "aide: no python found on PATH — install Python 3.11+ (python3)" >&2
exit 1
