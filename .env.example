# DeepSeek — auto-creates endpoint on first boot
DEEPSEEK_API_KEY=sk-...

# Anthropic (Claude) — auto-creates endpoint on first boot
ANTHROPIC_API_KEY=sk-ant-...

# generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# flip to true to enable password login
AUTH_ENABLED=false
AUTH_PASSWORD=changeme

PORT=8000

# optional — research mode web search (get a free key at tavily.com)
# without this, falls back to DuckDuckGo (limited results)
TAVILY_API_KEY=
